generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String   @id @default(uuid()) @db.Uuid
  name                      String
  username                  String   @unique
  password                  String
  role                      UserRole
  createdAt                 DateTime @default(now())
  whatsappNumber            String?
  performancePoints         Int      @default(0)
  monthlyPerformancePoints  Int      @default(0)
  lastMonthlyResetDate      DateTime?
  assignedCalls             ServiceRequest[]
  pointAdjustments          EmployeePointAdjustment[] @relation("EmployeePointAdjustments")
  performanceUpdates        EmployeePointAdjustment[] @relation("PointUpdatedBy")
  monthlyHistory            MonthlyPerformanceHistory[] @relation("MonthlyHistoryEmployee")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
}

model CallType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
}

model ServiceRequest {
  id           String   @id @default(uuid()) @db.Uuid
  docketNumber String   @unique
  name         String
  company      String
  phoneNumber1 String
  phoneNumber2 String?
  fullAddress  String
  complaintDetails String?
  area         String
  product      String
  callType     String
  serviceBillingType String?
  chargeableAmount Float?
  assignedToId String?  @db.Uuid
  assignedAt   DateTime?
  createdAt    DateTime @default(now())
  status       String?  @default("New Call")
  statusReason String?
  customerReview String?
  statusSubmittedAt DateTime?
  statusPointsDelta Int?
  reviewPointsDelta Int?
  closedByName String?
  closedAt     DateTime?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
}

model EmployeePointAdjustment {
  id                         String   @id @default(uuid()) @db.Uuid
  employeeId                 String   @db.Uuid
  updatedById                String?  @db.Uuid
  attendanceOption           String
  attendancePoints           Int
  reviewOption               String
  reviewPoints               Int
  documentSubmissionOption   String
  documentSubmissionPoints   Int
  materialHandoverOption     String
  materialHandoverPoints     Int
  teamworkOption             String
  teamworkPoints             Int
  totalDelta                 Int
  createdAt                  DateTime @default(now())

  employee                   User     @relation("EmployeePointAdjustments", fields: [employeeId], references: [id])
  updatedBy                  User?    @relation("PointUpdatedBy", fields: [updatedById], references: [id])
}

model MonthlyPerformanceHistory {
  id                 String   @id @default(uuid()) @db.Uuid
  employeeId         String   @db.Uuid
  year               Int
  month              Int
  totalPoints        Int      @default(0)
  createdAt          DateTime @default(now())
  
  employee           User     @relation("MonthlyHistoryEmployee", fields: [employeeId], references: [id])
  
  @@unique([employeeId, year, month])
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}
