generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  username       String   @unique
  password       String
  role           UserRole
  createdAt      DateTime @default(now())
  whatsappNumber String?
  assignedCalls  ServiceRequest[]
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
}

model CallType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
}

model ServiceRequest {
  id           String   @id @default(uuid()) @db.Uuid
  docketNumber String   @unique
  name         String
  company      String
  phoneNumber1 String
  phoneNumber2 String?
  fullAddress  String
  complaintDetails String?
  area         String
  product      String
  callType     String
  serviceBillingType String?
  chargeableAmount Float?
  assignedToId String?  @db.Uuid
  createdAt    DateTime @default(now())
  status       String?  @default("Pending")
  statusReason String?
  closedByName String?
  closedAt     DateTime?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}
